# Database
DATABASE_URL=postgresql://user:password@localhost:5432/mission_control_db

# FastAPI
FASTAPI_ENV=development
FASTAPI_DEBUG=true
FASTAPI_PORT=8000
FASTAPI_RELOAD=true

# Authentication
SECRET_KEY=your-secret-key-here-change-in-production

# Cost Tracking
COST_TRACKING_ENABLED=true

# Logging
LOG_LEVEL=INFO
