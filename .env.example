# =============================================================================
# Mission Control OS — environment template
# Copy this to .env (which IS gitignored) and replace placeholder values.
# Never commit .env. Never paste secrets in chat.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
ENV=dev

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mission_control_os
SQL_ECHO=false

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Tier 1 — REQUIRED to actually run missions
# =============================================================================

# Anthropic — Claude API for the decomposer + reviewer agents.
# Get: https://console.anthropic.com/settings/keys
# Set spend cap: https://console.anthropic.com/settings/limits  (recommend $10/mo to start)
# Format: sk-ant-...
ANTHROPIC_API_KEY=your-api-key-here

# =============================================================================
# Tier 2 — Music / agency analytics (unlocks real VS / LX / ATS workflows)
# =============================================================================

# Spotify Web API — VS / LX track analytics, playlist data, listener geography.
# Get: https://developer.spotify.com/dashboard  (Create app → Client ID + Secret)
# Cost: free, rate-limited.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Songstats — cross-platform aggregated music analytics (Apple/Spotify/Deezer/etc).
# Direct fulfillment of CLAUDE.md Data Protocol.
# Get: https://www.songstats.com/api  (paid tier ~$20/mo)
SONGSTATS_API_KEY=

# Chartmetric — alternative aggregated analytics; free tier exists.
# Get: https://api.chartmetric.com/  (account → API tab → Generate)
CHARTMETRIC_API_KEY=

# Instagram Graph API — VS / LX post analytics, Wakanda / ATS post scheduling.
# Setup: requires Meta Business + Instagram Business profile + Facebook app
# Get: https://developers.facebook.com/  (~30 min of setup; weekend project)
INSTAGRAM_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# =============================================================================
# Tier 3 — Hosting (defer until you actually deploy)
# =============================================================================

# Vercel CLI is already authenticated as mackinmacmini-5346 — no token needed
# unless you want a programmatic CI token.
# Get: https://vercel.com/account/tokens
# VERCEL_TOKEN=

# Railway — backend hosting if you outgrow local Postgres.
# Get: https://railway.app/account/tokens
# RAILWAY_TOKEN=

# =============================================================================
# Tier 4 — Optional / specialty
# =============================================================================

# OpenAI — backup LLM if Anthropic ever rate-limits, or alternative embeddings.
# Honest read: skip unless you actually want a backup.
# Get: https://platform.openai.com/api-keys
# OPENAI_API_KEY=

# ElevenLabs — voice synthesis (could power London X content workflows).
# Get: https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=

# Brave Search — already set globally for the brave-search MCP, doesn't need
# to be in this file unless you want a project-specific override.
# BRAVE_API_KEY=

# =============================================================================
# Cost tracking (Mission Control internal)
# =============================================================================
COST_TRACKING_ENABLED=true
COST_LIMIT_USD=100.0

# =============================================================================
# Execution limits (Mission Control internal)
# =============================================================================
MAX_TASK_ITERATIONS=3
MAX_CONCURRENT_TASKS=1
TASK_TIMEOUT_SECONDS=300
